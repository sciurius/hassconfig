# Generic IR                      -*- hass -*-

[% PROCESS ir_action.tt; remote = "slaapkamer";

   MACRO button(command) BLOCK;
     "type: markdown\n";
     "        title: false\n";
     "        content: '<center><b>"; command.replace("_"," ").upper() ;"</b></center>'\n";
     "        tap_action: "; ir_perform(remote,device,command); "\n";
     "        hold_action: "; ir_perform(remote,device,command); "\n";
     "        card_mod:\n";
     "          style:\n";
     "            .: |\n";
     "              ha-card { background: lightgrey; }\n";       
   END;

   max_cols = 6;
   width    = 150;
%]

title: Remote Devices
views:

  - title: philips_tv
    type: custom:horizontal-layout
    layout:
      max_cols: [% max_cols %]
      width: [% width %]
    cards:
      [%- device = "tv"; "\n";
         FOREACH b IN
           [ "key_0",
             "key_1",
             "key_2",
             "key_3",
             "key_4",
             "key_5",
             "key_6",
             "key_7",
             "key_8",
             "key_9",
             "previous_channel",
             "power",
             "mute",
             "info",
             "volume_up",
             "volume_down",
             "channel_up",
             "channel_down",
             "fast_forward",
             "rewind",
             "pause",
             "stop",
             "play",
             "record",
             "next_source",
             "teletext",
             "standby",
             "option",
             "closed_captions",
             "subtitles",
             "menu",
             "cursor_up",
             "cursor_down",
             "cursor_left",
             "cursor_right",
             "ok",
             "red",
             "green",
             "yellow",
             "blue",
             "white",
             "exit",
             "settings",
             "guide",
             "channel_list",
             "teletext",
           ]; "      - "; button(b); END %]

  - title: hdmi_switch
    type: custom:horizontal-layout
    layout:
      max_cols: [% max_cols %]
      width: [% width %]
    cards:
      [%- device = "hdmiswitch"; "\n";
         FOREACH b IN
           [ "input1",
             "input2",
             "input3",
             "input4",
             "in_auto",
             "ch_20",
             "ch_51",
             "ch_71",
             "ch_auto",
             "arc",
           ]; "      - "; button(b); END %]

  - title: vip1853
    type: custom:horizontal-layout
    layout:
      max_cols: [% max_cols %]
