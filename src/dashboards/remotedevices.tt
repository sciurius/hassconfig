             "key_7",
             "key_8",
             "key_9",
             "key_0",
             "power",
             "play_pause",
             "rewind",
             "fast_forward",
             "stop",
             "record",
             "red",
             "green",
             "yellow",
             "blue",
             "up",
             "down",
             "left",
             "right",
             "ok",
             "menu",
             "tv",
             "guide",
             "radio",
             "back",
             "channel_up",
             "channel_down",
             "volume_up",
             "volume_down",
             "mute",
             "source",
             "text",
           ]; "      - "; button(b); END %]

  - title: smsl_ad18
    type: custom:horizontal-layout
    layout:
      max_cols: [% max_cols %]
      width: [% width %]
    cards:
      [%- device = "audio"; "\n";
         FOREACH b IN
           [ "power",
             "mute",
             "volume_up",
             "a_left",
             "settings",
             "a_right",
             "volume_down",
             "input",
             "fn",
             "b_power",
             "b_mute",
             "b_up",
             "b_left",
             "b_enter",
             "b_right",
             "b_down",
             "b_input",
             "b_fn",
             "c_power",
             "c_mute",
             "c_up",
             "c_left",
             "c_enter",
             "c_right",
             "c_down",
             "c_mode",
             "c_fn",
           ]; "      - "; button(b); END %]

